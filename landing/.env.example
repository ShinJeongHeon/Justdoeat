# Supabase 연결 정보 템플릿.
# 이 파일을 복사해 landing/.env 로 만들고 실제 값을 채운다.
#   cp .env.example .env
# Vite는 VITE_ 접두사가 붙은 변수만 클라이언트 코드(import.meta.env)에 노출한다.

# Supabase 프로젝트 URL (예: https://xxxx.supabase.co)
VITE_SUPABASE_URL=

# Supabase publishable(anon) 키 — 브라우저 노출 가능. 쓰기 권한은 RLS로 제한.
VITE_SUPABASE_PUBLISHABLE_KEY=
